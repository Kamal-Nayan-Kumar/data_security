{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT p.id, p.name, p.developer_id, p.description, p.created_at, d.public_key as \"developer_public_key!\"\n        FROM packages\n        p\n        INNER JOIN developers d ON d.id = p.developer_id\n        WHERE p.name = $1\n        ",
